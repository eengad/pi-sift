{
  "name": "pi-context-lens",
  "version": "0.1.0",
  "description": "Model-driven context summarization extension for Pi Coding Agent",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/index.test.ts src/validation.test.ts",
    "validate": "npm run check && npm run test",
    "validate:real": "./scripts/validate-real-pi.sh",
    "benchmark:swe-pipeline-ab": "./scripts/benchmark-swe-pipeline-ab.sh"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "extension",
    "context",
    "summarization"
  ],
  "author": "Eyal En Gad",
  "license": "MIT",
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.54.0"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.54.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
